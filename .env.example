LLM_PROVIDER=vertex
LLM_MODEL=

VERTEX_PROJECT_ID=<your-gcp-project-id>
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.5-flash
GOOGLE_APPLICATION_CREDENTIALS=/secret/gcp-creds.json

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=xlerobot-pro
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# ZMQ camera-server (lerobot camera_server.py)
ZMQ_SERVER_HOST=localhost
ZMQ_SERVER_PORT=5555

# VLA inference
VLA_INFERENCE_SERVER=192.168.50.42:8080
ROBOT_PORT=/dev/ttyACM0
ROBOT_ID=left_arm
